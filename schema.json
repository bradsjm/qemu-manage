{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/bradsjm/qemu-manage/main/schema.json",
  "title": "qemu-manage VM configuration",
  "description": "Canonical durable VM configuration emitted by qemu-manage. Cross-field and cross-item invariants remain authoritative in qemu-manage config validate.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema", "schema_version", "id", "name", "backend", "architecture", "uuid", "cpus", "memory_mib",
    "restart_policy", "shutdown_timeout_seconds", "firmware", "disks", "network", "guest_agent", "qemu", "autostart"
  ],
  "properties": {
    "$schema": { "type": "string", "const": "https://raw.githubusercontent.com/bradsjm/qemu-manage/main/schema.json" },
    "schema_version": { "type": "integer", "const": 1 },
    "id": { "type": "string", "pattern": "^[0-9a-f]{32}$" },
    "name": { "type": "string", "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._-]{0,62}$" },
    "backend": { "type": "string", "const": "qemu" },
    "architecture": { "type": "string", "const": "aarch64" },
    "uuid": { "type": "string", "pattern": "^[0-9A-Fa-f]{8}-[0-9A-Fa-f]{4}-4[0-9A-Fa-f]{3}-[89ABab][0-9A-Fa-f]{3}-[0-9A-Fa-f]{12}$" },
    "cpus": { "type": "integer", "minimum": 1, "maximum": 64 },
    "memory_mib": { "type": "integer", "minimum": 256 },
    "restart_policy": { "type": "string", "enum": ["never", "on-failure"] },
    "shutdown_timeout_seconds": { "type": "integer", "minimum": 1, "maximum": 3600 },
    "firmware": { "$ref": "#/$defs/firmware" },
    "installer": { "$ref": "#/$defs/installer" },
    "disks": { "$ref": "#/$defs/disks" },
    "network": { "$ref": "#/$defs/network" },
    "guest_agent": { "$ref": "#/$defs/guestAgent" },
    "vnc": { "$ref": "#/$defs/vnc" },
    "metrics": { "$ref": "#/$defs/metrics" },
    "usb": { "type": "array", "minItems": 1, "maxItems": 4, "uniqueItems": true, "items": { "$ref": "#/$defs/usbDevice" } },
    "qemu": { "$ref": "#/$defs/qemu" },
    "autostart": { "$ref": "#/$defs/autostart" }
  },
  "allOf": [
    {
      "if": { "required": ["vnc"], "properties": { "vnc": { "type": "object" } } },
      "then": { "properties": { "usb": { "maxItems": 2 } } }
    }
  ],
  "$defs": {
    "firmware": {
      "type": "object", "additionalProperties": false, "required": ["code", "variables"],
      "properties": { "code": { "type": "string", "minLength": 1 }, "variables": { "type": "string", "minLength": 1 } }
    },
    "installer": {
      "type": "object", "additionalProperties": false, "required": ["path", "boot_index"],
      "properties": { "path": { "type": "string", "minLength": 1 }, "boot_index": { "type": "integer", "minimum": 0 } }
    },
    "disk": {
      "type": "object", "additionalProperties": false,
      "required": ["path", "format", "serial", "boot_index", "read_only"],
      "properties": {
        "path": { "type": "string", "minLength": 1 }, "format": { "type": "string", "enum": ["qcow2", "raw"] },
        "serial": { "type": "string", "pattern": "^[A-Za-z0-9._-]{1,64}$" },
        "boot_index": { "type": "integer", "minimum": 0 }, "read_only": { "type": "boolean" },
        "cache": { "type": "string", "enum": ["none", "writeback", "writethrough", "directsync", "unsafe"] }
      }
    },
    "disks": { "oneOf": [{ "type": "null" }, { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/disk" } }] },
    "ipv4": {
      "type": "string", "format": "ipv4",
      "pattern": "^(?:(?:25[0-5]|2[0-4][0-9]|1[0-9]{2}|[1-9]?[0-9])\\.){3}(?:25[0-5]|2[0-4][0-9]|1[0-9]{2}|[1-9]?[0-9])$"
    },
    "portForward": {
      "type": "object", "additionalProperties": false, "required": ["protocol", "host_address", "host_port", "guest_port"],
      "properties": {
        "protocol": { "type": "string", "enum": ["tcp", "udp"] }, "host_address": { "$ref": "#/$defs/ipv4" },
        "host_port": { "type": "integer", "minimum": 1, "maximum": 65535 }, "guest_port": { "type": "integer", "minimum": 1, "maximum": 65535 }
      }
    },
    "socketVMNet": {
      "type": "object", "additionalProperties": false, "required": ["client_path", "socket_path", "interface"],
      "properties": { "client_path": { "type": "string", "pattern": "^/" }, "socket_path": { "type": "string", "pattern": "^/" }, "interface": { "type": "string", "minLength": 1 } }
    },
    "network": {
      "type": "object", "additionalProperties": false, "required": ["mode", "mac", "forwards"],
      "properties": {
        "mode": { "type": "string", "enum": ["user", "socket_vmnet"] }, "mac": { "type": "string", "pattern": "^[0-9a-f][26ae](?::[0-9a-f]{2}){5}$" },
        "forwards": { "oneOf": [{ "type": "null" }, { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/portForward" } }] },
        "socket_vmnet": { "$ref": "#/$defs/socketVMNet" }, "smb_folder": { "type": "string", "pattern": "^/", "minLength": 1 }
      },
      "allOf": [
        { "if": { "required": ["mode"], "properties": { "mode": { "const": "user" } } }, "then": { "not": { "required": ["socket_vmnet"] } } },
        { "if": { "required": ["mode"], "properties": { "mode": { "const": "socket_vmnet" } } }, "then": { "required": ["socket_vmnet"], "not": { "required": ["smb_folder"] }, "properties": { "forwards": { "oneOf": [{ "type": "null" }, { "type": "array", "maxItems": 0 }] } } } }
      ]
    },
    "guestAgent": { "type": "object", "additionalProperties": false, "required": ["enabled"], "properties": { "enabled": { "type": "boolean" } } },
    "metrics": { "type": "object", "additionalProperties": false, "required": ["port"], "properties": { "port": { "type": "integer", "minimum": 1024, "maximum": 65535 } } },
    "vnc": {
      "type": "object", "additionalProperties": false, "required": ["bind", "port", "port_to", "password"],
      "properties": {
        "bind": { "$ref": "#/$defs/ipv4" }, "port": { "type": "integer", "minimum": 5900, "maximum": 65535 }, "port_to": { "type": "integer", "minimum": 5900, "maximum": 65535 },
        "password": { "type": "string", "description": "VNC password; qemu-manage enforces a 1-8 UTF-8 byte limit. JSON Schema length keywords count Unicode characters, so this constraint is approximate for non-ASCII passwords.", "minLength": 1, "maxLength": 8, "not": { "pattern": "\\u0000" } },
        "keyboard_layout": { "type": "string", "enum": ["ar", "da", "de", "de-ch", "en-gb", "en-us", "es", "et", "fi", "fo", "fr", "fr-be", "fr-ca", "fr-ch", "hr", "hu", "is", "it", "ja", "lt", "lv", "mk", "nl", "nl-be", "no", "pl", "pt", "pt-br", "ru", "sl", "sv", "th", "tr"] }
      }
    },
    "usbDevice": {
      "oneOf": [
        { "type": "object", "additionalProperties": false, "required": ["vendor_id", "product_id"], "properties": { "vendor_id": { "type": "string", "pattern": "^(?!0000$)[0-9a-f]{4}$" }, "product_id": { "type": "string", "pattern": "^(?!0000$)[0-9a-f]{4}$" } } },
        { "type": "object", "additionalProperties": false, "required": ["host_bus", "host_address"], "properties": { "host_bus": { "type": "integer", "minimum": 1, "maximum": 255 }, "host_address": { "type": "integer", "minimum": 1, "maximum": 127 } } }
      ]
    },
    "qemu": {
      "type": "object", "additionalProperties": false, "required": ["binary", "image_tool", "machine", "extra_args"],
      "properties": {
        "binary": { "type": "string" }, "image_tool": { "type": "string" }, "machine": { "oneOf": [{ "const": "" }, { "const": "virt" }, { "type": "string", "pattern": "^virt-[1-9][0-9]*\\.[0-9]+$" }] },
        "rtc_base": { "type": "string", "enum": ["utc", "localtime"] }, "extra_args": { "oneOf": [{ "type": "null" }, { "type": "array", "items": { "type": "string" } }] }
      }
    },
    "autostart": { "type": "object", "additionalProperties": false, "required": ["scope"], "properties": { "scope": { "type": "string", "enum": ["none", "boot", "login"] } } }
  }
}
